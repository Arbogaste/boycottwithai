---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<head>
  <title>BoycottWithAI — Zivilwiderstand gegen Manipulation, Umweltzerstörung und Speziesismus</title>
  <meta name="description" content="Praktische Tools für gewaltfreie Aktionen: OSINT, ethische KI, disruptive Materialien gegen Faschismus, Desinformation, Wolfsabschüsse, Klimakrise. Kampagnen, Daten und Ressourcen für globale Gerechtigkeit." />
  <meta name="keywords" content="Zivilwiderstand Deutschland, gewaltfreie Aktionen, gegen Faschismus 2025, Umweltgerechtigkeit, Tierrechte, OSINT Ethik, KI Transparenz, Desinformationskampf, Klimakrise, Speziesismus, Mutualismus, digitaler Antifaschismus" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://boycottwithai.com/de/" />
</head>

<Base>
  <div class="hero">
    <div class="left">
      <h1>Zivilwiderstand: handeln Sie jetzt gegen Faschismus, Ausbeutung und Wiederbewaffnung</h1>
      <p class="lead">Digitale Tools und praktische Materialien, um Manipulation, Wiederbewaffnung als „Sicherheit“ getarnt, Klimakrise und Repression aufzudecken. Verteidigen Sie öffentliche Dienste, Umwelt und demokratische Kontrolle.</p>
      <p class="muted">2025: steigende Militärbudgets unter dem Vorwand der Sicherheit, während soziale Dienste gekürzt werden. Dokumentieren Sie Verstöße gegen EU-Recht und erstellen Sie Dossiers für Vertragsverletzungsverfahren.</p>
      <div class="cta">
        <a class="button" href={`/${lang}/actions/`}>Disruptive Aktionen</a>
        <a class="secondary" href={`/${lang}/tools-resources/`}>OSINT Tools</a>
        <a class="secondary" href={`/${lang}/resources/`}>Materialien herunterladen</a>
      </div>
    </div>
    <div class="card">
      <h3>Dringende Alarme</h3>
      <p class="muted">RSS für Kampagnen-Updates, Daten und Aktionsaufrufe.</p>
      <a class="secondary" href="/rss.xml">Abonnieren</a>
    </div>
  </div>

  <section style="margin-top:28px">
    <div class="grid">
      <div class="card">
        <h4>Warum jetzt?</h4>
        <ul>
          <li><strong>Manipulation:</strong> Kontrollierte Medien verbreiten Hass und Lügen.</li>
          <li><strong>Ausbeutung:</strong> Kapital nutzt Staat für Profit, ignoriert Arme und Natur.</li>
          <li><strong>Repression:</strong> Rechte Kürzungen, Tierabschüsse, soziale Kontrolle.</li>
        </ul>
      </div>
      <div class="card">
        <h4>Schlüsselaktionen</h4>
        <ul>
          <li><a href={`/${lang}/actions/`}>10 Disruptive Aktionen</a> (Spekulationskarten, Satire, Crowdfund)</li>
          <li><a href={`/${lang}/tools-resources/`}>OSINT & KI Überwachung</a> (GDELT, Bellingcat, Sentiment)</li>
          <li><a href={`/${lang}/resources/`}>Vorlagen & Daten</a> (Petitionen, Briefings, Dashboards)</li>
        </ul>
      </div>
      <div class="card">
        <h4>Sicherheit</h4>
        <p class="muted">Anonymität und Datenschutz: nutzen Sie Tor, minimale Daten, sichere Meldungen.</p>
      </div>
    </div>
  </section>

  <section style="margin-top:18px">
    <div class="card" style="border-left:4px solid #c33;">
      <h4>EU-Verstöße melden — Italien / Frankreich / Deutschland</h4>
      <p class="muted">Priorität für dokumentierte Verstöße gegen Umweltrecht, Abwasserbehandlung, Abfallwirtschaft und öffentliche Beschaffung. Helfen Sie uns, belastbare Beweismappen zu erstellen.</p>
      <p style="margin-top:6px"><strong>Wichtige EU-Rechtsakte:</strong></p>
      <ul>
        <li><a href="https://eur-lex.europa.eu/eli/dir/2008/50/oj" target="_blank" rel="noopener">Richtlinie 2008/50/EG — Luftqualität</a></li>
        <li><a href="https://eur-lex.europa.eu/eli/dir/1991/271/oj" target="_blank" rel="noopener">Richtlinie 91/271/EWG — Abwasserbehandlung</a></li>
        <li><a href="https://eur-lex.europa.eu/eli/dir/2008/98/oj" target="_blank" rel="noopener">Richtlinie 2008/98/EG — Abfallrahmen</a></li>
        <li><a href="https://eur-lex.europa.eu/eli/dir/2014/24/oj" target="_blank" rel="noopener">Richtlinie 2014/24/EU — Öffentliche Auftragsvergabe</a></li>
      </ul>
      <p class="muted">Zu sammeln: offizielle Messdaten, Verwaltungsakte, Verträge, geotagged Fotos, chronologische Ereignisse. Nutzen Sie unsere Vorlagen.</p>
      <div style="margin-top:8px">
        <a class="secondary" href="/templates/infringement-report-de.md" download aria-label="Vorlage Herunterladen (DE)">Vorlage herunterladen (DE)</a>
        <a class="secondary" href="/downloads/resources/priority-infractions-de.md" style="margin-left:8px">Priority-Infractions (DE)</a>
      </div>
    </div>
  </section>

  <section style="margin-top:28px">
    <h2>Globale Probleme und Regionale Besonderheiten</h2>
    <div class="grid">
      <div class="card">
        <h4>Wiederbewaffnung und Militarisierung</h4>
        <p class="muted">Globale Militärausgaben +12% in 10 Jahren (SIPRI). Regierungen rechtfertigen mit Ängsten für wirtschaftliche Anreize.</p>
        <p><strong>Aktion:</strong> Fordern Sie Transparenz Verteidigungsbudgets, Vertragsaudits.</p>
      </div>
      <div class="card">
        <h4>Umweltkrise</h4>
        <p class="muted">Erwärmung >1.5°C, Biodiversitätsverlust 70% (IPCC/UN). Privater Profit verursacht Entwaldung, Verschmutzung.</p>
        <p><strong>Aktion:</strong> Gerechte Energiewende, Ende fossiler Subventionen, Schutz Gebiete.</p>
      </div>
      <div class="card">
        <h4>Speziesismus und Tierausbeutung</h4>
        <p class="muted">Wolfsabschüsse Italien +200% seit 2020, Jagd, industrielle Tierhaltung. Tierleben geopfert für Profit.</p>
        <p><strong>Aktion:</strong> Jagdverbote, Raubtierschutz, ethischer Veganismus, Tierrechte.</p>
      </div>
    </div>
    <div class="card" style="margin-top:18px">
      <h4>Deutschland-spezifische Kritiken 2025</h4>
      <ul>
        <li><strong>Umwelt:</strong> Ruhr Verschmutzung, bayerische Entwaldung, Energiekrise post-Ukraine.</li>
        <li><strong>Tiermarkt:</strong> Hirschjagd, industrielle Tierhaltung, Wildtierhandel.</li>
        <li><strong>Sozial:</strong> Austerität, Ungleichheit Anstieg, schwache antifaschistische Repression.</li>
      </ul>
      <p><strong>Konkrete Aktionen:</strong> Unterzeichnen Sie Petitionen gegen Jagd, überwachen Sie Umweltverordnungen, schließen Sie sich lokalen Kampagnen an.</p>
    </div>
  </section>

  <section class="alert-danger">
    <h2 style="margin-top: 0;">🔴 USA-israelischer Krieg gegen den Iran (2025–2026): Dokumentierte Analyse</h2>
    <p><strong>Minab-Massaker:</strong> 148-175 Schulmädchen und Lehrer in einzelnem Bombardement getötet. 600+ Schulen zerstört. 130+ dokumentierte Kriegsverbrechen. Aufgedeckte Schwächen der US-Militärkapazität + unvermeidliche wirtschaftliche Folgen.</p>
    <p style="margin-top:12px"><a href={`/${lang}/iran-war/`} style="font-weight: bold; color: #cc0000; font-size: 1.1em;">→ Vollständige Untersuchung lesen: Kriminalistik, geopolitische Kollapsszenarien, makroökonomische Prognosen</a></p>
  </section>

  <section style="margin-top:28px">
    <div class="card">
      <h4>Sofortige Ressourcen</h4>
      <ul>
        <li>Laden Sie <a href="/downloads/templates/petition-de.txt">Petition</a> oder <a href="/downloads/templates/mp-email-de.txt">Abgeordneten-Email</a> herunter</li>
        <li>Lesen Sie <a href={`/${lang}/investigations/`}>dokumentierte Ermittlungen</a> über Verschmutzung, Ausbeutung, Militarisierung</li>
        <li>Greifen Sie auf <a href={`/${lang}/resources/`}>detaillierte technische Materialien</a> für Scraping, KI, Video zu</li>
        <li>Unterzeichnen Sie Kampagnen: <a href="https://change.org/stop-wolf-culls" target="_blank">Gegen Wolfsabschüsse</a>, <a href="https://change.org/klimagerechtigkeit" target="_blank">Für Klimagerechtigkeit</a></li>
      </ul>
    </div>

    <div class="card" style="margin-top:18px;border:2px solid var(--accent);background:rgba(255,107,107,0.05)">
      <h3>🚨 Nehmen Sie Ihre Sozialen Medien Zurück: Bekämpfen Sie Desinformation</h3>
      <p style="font-weight:600;margin-top:8px">Wenn Sie noch auf Instagram, Facebook oder Twitter sind — handeln Sie jetzt:</p>
      
      <div style="margin-top:16px">
        <h4 style="color:var(--accent)">Schritt 1: Desinformation Melden und Blockieren</h4>
        <ol style="margin-top:8px">
          <li><strong>Finden Sie Beiträge</strong>, die Desinformation, Gewalt oder Propaganda von Medien/Personen verbreiten</li>
          <li><strong>Melden Sie den Beitrag</strong> — klicken Sie "Melden" und wählen Sie "Falsche Information" oder "Gewalttätiger Inhalt"</li>
          <li><strong>Melden Sie das Konto</strong> — besuchen Sie das Profil und wählen Sie "Konto melden", wenn es Wiederholungstäter sind</li>
          <li><strong>Blockieren Sie es</strong> — nutzen Sie die Blockfunktion, um zu verhindern, dass ihre Inhalte in Ihrem Feed erscheinen</li>
          <li><strong>Sichern Sie Beweise</strong> (sicher Screenshots/Archive), bevor die Plattform den Inhalt löscht</li>
        </ol>
      </div>

      <div style="margin-top:16px">
        <h4 style="color:var(--accent)">Schritt 2: Verlassen Sie Giftige Plattformen (Vollversion)</h4>
        <ul style="margin-top:8px">
          <li>❌ <strong>Löschen Sie TikTok, Facebook, Instagram</strong> — sie profitieren von Abhängigkeit und Aufmerksamkeit, von Staaten und Konzernen als Waffen eingesetzt</li>
          <li>✅ <strong>Abonnieren Sie <a href="https://upscrolled.com/en/" target="_blank" rel="noopener">Upscrolled</a></strong> — kuratierter Newsletter, werbefrei, von Menschen redigiert, Fokus auf Lösungen</li>
          <li>✅ <strong>Nutzen Sie RSS-Feeds</strong> — abonnieren Sie vertrauenswürdige Quellen  über RSS-Reader (Feedly) für vollständige Kontrolle</li>
        </ul>
      </div>

      <div style="margin-top:16px">
        <h4 style="color:var(--accent)">Schritt 3: Sichern Sie Ihre Kommunikation</h4>
        <ul style="margin-top:8px">
          <li>🔴 <strong style="color:var(--accent)">Hören Sie auf, WhatsApp</strong> für sensible Kommunikation zu nutzen — Eigentum von Meta (Facebook)</li>
          <li>🟢 <strong style="color:var(--accent)">Verwenden Sie Signal</strong> (verschlüsselt, Open-Source, gemeinnützig). Laden Sie herunter und teilen Sie Ihr Signal-Profil</li>
          <li>🟡 <strong style="color:var(--accent)">Telegram</strong> nur wenn nötig (verschlüsselt, Closed-Source; verwenden Sie "Geheime Chats")</li>
        </ul>
      </div>

      <p class="muted" style="margin-top:16px;font-size:0.9em">💡 <strong>Warum das wichtig ist:</strong> Diese Plattformen verstärken divisive Inhalte und Desinformation algorithmisch. Sie verkaufen Ihre Daten. Das Verlassen reduziert ihre Macht und Ihre Exposition gegenüber Manipulation.</p>
    </div>
  </section>

  <section style="margin-top:28px">
    <div class="card" style="background:rgba(200,50,100,0.05);border-left:4px solid #c832">
      <h4>Epstein-Akten: Machtnetze Enthüllt</h4>
      <p class="muted"><strong>60.000+ Seiten offiziell freigegeben (2025).</strong> Institutionelle Versäumnisse, Geldflüsse, Mitschuldnetze enthüllt.</p>
      <p style="margin-top:12px"><strong>Wählen Sie Ihren Ansatz:</strong></p>
      <ul style="padding-left:20px;margin-top:8px">
        <li><strong>Schnelle Suche:</strong> <a href="https://jmail.world" target="_blank" rel="noopener">JMail.world</a> — durchsuchbare E-Mail-Datenbank aus exponierten Netzen</li>
        <li><strong>Tiefanalyse:</strong> <a href={`/${lang}/tools-resources/#epstein`}>Laden Sie die vollständige Methodik herunter</a> — reproduzierbarer Arbeitsablauf zum eigenständigen Erwerben, Verarbeiten und Analysieren von 60.000+ Dokumenten mit Python OCR, SQLite FTS5-Datenbank, Entity-Extraktion, Co-Occurrence-Analyse und Timeline-Rekonstruktion</li>
      </ul>
      <p style="margin-top:12px;font-size:0.9em;color:#666"><strong>Warum Autonomie zählt:</strong> Erstellen Sie Ihre eigene durchsuchbare Datenbank. Überprüfen Sie die Ergebnisse. Kontrollieren Sie die Analyse. Aktualisierte Quellen, Tools und Schritt-für-Schritt-Guides enthalten.</p>
    </div>
  </section>

</Base>
